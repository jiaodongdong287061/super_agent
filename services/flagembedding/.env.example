# FlagEmbedding 模型推理服务配置

# 设备模式: "cpu" / "cuda" / "cuda:0"
FE_DEVICE=cpu

# Embedding 模型（默认 BGE-M3，支持 truncate_dim）
FE_EMBED_MODEL=BAAI/bge-m3

# Reranker 模型
FE_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Embedding 维度
# BGE-M3: 支持 1024 / 2048 / 4096（需模型支持 truncate_dim）
# BGE-large-zh-v1.5: 固定 1024，设此值无效
# 如果你的 Qdrant 向量维度是 2048，这里就设 2048，无需重建索引
FE_EMBED_DIM=2048

# 服务监听配置
FE_HOST=0.0.0.0
FE_PORT=8001
FE_LOG_LEVEL=INFO
