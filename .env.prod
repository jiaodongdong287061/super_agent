# 运行环境：dev=开发, prod=生产
SA_ENV=dev

# OneAPI 统一网关地址
SA_LLM_ONEAPI_BASE_URL=https://apirouter.topprismdata.com/v1
# OneAPI 认证密钥
SA_LLM_ONEAPI_API_KEY=sk-qsLlqynthVOswocNuLq3snRJhaWVWmIraN3wtvH3cSTHu1Up
# 默认使用的 LLM 模型名称
SA_LLM_DEFAULT_MODEL=deepseek-v4-flash-202605

# Embedding 提供方：bge=本地 BGE 模型, api=远程 Embedding API
SA_EMBEDDING_PROVIDER=api
# BGE 模型名称（本地模式生效）
SA_EMBEDDING_BGE_MODEL_NAME=BAAI/bge-large-zh-v1.5
# BGE 推理设备：cpu 或 cuda（本地模式生效）
SA_EMBEDDING_BGE_DEVICE=cpu
# 远程 Embedding API 地址（API 模式生效）
SA_EMBEDDING_API_URL=https://open.bigmodel.cn/api/paas/v4/embeddings
# 远程 Embedding API 密钥（API 模式生效）
SA_EMBEDDING_API_KEY=4a244a030d9d4ad79574869ea147931e.cCwgAFFZz1gvpaeV
# 远程 Embedding API 密钥（API 模式生效）
#SA_EMBEDDING_API_KEY=c9baaee1cd964e58b8d43901fd95dc34.QRKwpuGDsQ6S7ZOI
# 远程 Embedding 模型名称（API 模式生效）
SA_EMBEDDING_API_MODEL=embedding-3
# Embedding API 单次请求最大输入条数
SA_EMBEDDING_API_BATCH_SIZE=64

# Reranker 重排序（默认关闭，开启需部署远程 Reranker API 服务）
#SA_RERANK_PROVIDER=remote
#SA_RERANK_API_URL=http://flagembedding:8001/v1/rerank
#SA_RERANK_API_KEY=
#SA_RERANK_TOP_N=0

# 向量库提供方：chroma=ChromaDB, milvus=Milvus, qdrant=Qdrant
SA_VECTOR_PROVIDER=qdrant
# Chroma 持久化存储路径（Chroma 模式生效）
SA_VECTOR_CHROMA_PERSIST_DIR=./data/chroma
# Qdrant 服务地址（Qdrant 模式生效）
SA_VECTOR_QDRANT_URL=http://10.1.1.19:31244
# Qdrant 集合名称（Qdrant 模式生效）
SA_VECTOR_QDRANT_COLLECTION=super_agent_docs
# Qdrant API 密钥（Qdrant 模式生效，无鉴权可留空）
SA_VECTOR_QDRANT_API_KEY=7s9kP2RgT5xQz8bNvDcF4mLjh0Y6aUwG1e
# Qdrant 向量维度（必须与 Embedding 模型输出维度一致）
SA_VECTOR_QDRANT_VECTOR_SIZE=2048
# Qdrant 距离算法：COSINE / EUCLID / DOT
SA_VECTOR_QDRANT_DISTANCE=COSINE

# Redis 连接地址（用于短时记忆和缓存）
SA_REDIS_URL=redis://localhost:6379/15
SA_REDIS_PASSWORD=


# MySQL 主机地址
SA_MYSQL_HOST=localhost
# MySQL 端口
SA_MYSQL_PORT=3306
# MySQL 用户名
SA_MYSQL_USERNAME=root
# MySQL 密码
SA_MYSQL_PASSWORD=123456
# MySQL 数据库名
SA_MYSQL_DATABASE=super_agent

# LangSmith 开发期追踪（用于调试 RAG 检索效果，数据上传到 LangSmith SaaS）
SA_TRACING_ENABLE_LANGSMITH=false
# LangSmith API 密钥（开通 https://smith.langchain.com 获取）
SA_TRACING_LANGSMITH_API_KEY=
# LangSmith 项目名
SA_TRACING_LANGSMITH_PROJECT=super-agent
# OpenTelemetry 生产期全链路追踪（数据写入 Jaeger，不传出本地）
SA_TRACING_ENABLE_OTEL=false
# OTel Collector / Jaeger 导出地址（Jaeger all-in-one 默认端口 4317）
SA_TRACING_OTEL_EXPORTER=http://localhost:4317
# OTel 服务名称（在 Jaeger UI 中标识服务）
SA_TRACING_OTEL_SERVICE_NAME=super-agent-dev

# RAG 检索配置
SA_RAG_ENABLE_METRICS=true
SA_RAG_ENABLE_AUDIT=true
SA_RAG_ENABLE_QUERY_REWRITE=true
# 查询扩展：生成多同义变体分别检索扩大召回（需 LLM，耗时+耗 token）
SA_RAG_ENABLE_QUERY_EXPANSION=false
# 意图分类：识别 query 类型(qa/summarize/instruction)，调整下游 prompt
SA_RAG_ENABLE_INTENT_CLASSIFICATION=true
# BM25 混合检索开关（启用后索引和检索均使用 ES BM25 + 向量双路 → RRF 融合）
# 注意：本地开发需先启动 ES 服务，否则设为 false
SA_RAG_ENABLE_BM25_HYBRID=false
# LLM 自动打标：索引时对无手动标注的文档调用 LLM 生成 topic_tags（成本较高）
#SA_RAG_ENABLE_LLM_TAGGING=true

# Elasticsearch 配置（BM25 混合检索用）
SA_ES_HOSTS=http://10.1.1.19:31242
SA_ES_INDEX_NAME=super_agent_docs

# 服务监听端口
SA_SERVER_PORT=8000
# 日志级别：DEBUG, INFO, WARNING, ERROR
SA_SERVER_LOG_LEVEL=DEBUG

# OAuth2 SSO 认证（false=开发环境跳过认证）
SA_SSO_ENABLE=true
# 授权中心 OAuth2 客户端 ID
SA_SSO_CLIENT_ID=super-agent
# 授权中心 OAuth2 客户端密钥
SA_SSO_CLIENT_SECRET=super-agent
# 授权中心认证地址
SA_SSO_AUTH_BASE_URL=http://localhost:8081
# 回调地址（必须与授权中心注册的一致）
SA_SSO_REDIRECT_URI=http://localhost:8000/auth/callback
# 前端地址（登录成功后重定向到此处）
SA_SSO_FRONTEND_URL=http://localhost:8000
# JWT 签名密钥（HS512），必须与 Java SSO 端 JwtUtils 中的 secret 一致
# 建议使用 4 的倍数长度（如 24/28/32 字符），避免 Java DatatypeConverter 丢弃尾部
SA_SSO_JWT_SECRET=abcdefghijklmnopqrstuvwxyz
# SSO 的 Redis 地址（用于验证 token 注销状态）
SA_SSO_REDIS_URL=redis://localhost:6379/6
# SSO 的 Redis 密码（生产环境必填）
SA_SSO_REDIS_PASSWORD=
