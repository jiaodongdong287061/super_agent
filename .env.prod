# 运行环境：dev=开发, prod=生产
SA_ENV=prod

# OneAPI 统一网关地址（Docker 容器间使用服务名）
SA_LLM_ONEAPI_BASE_URL=http://oneapi:3000/v1
# OneAPI 认证密钥（通过环境变量注入）
SA_LLM_ONEAPI_API_KEY=${ONEAPI_API_KEY}
# 默认使用的 LLM 模型名称
SA_LLM_DEFAULT_MODEL=gpt-4o

# Embedding 提供方：bge=本地 BGE 模型, api=远程 Embedding API
SA_EMBEDDING_PROVIDER=api
# 远程 Embedding API 地址（API 模式生效）
SA_EMBEDDING_API_URL=${EMBEDDING_API_URL}
# 远程 Embedding API 密钥（API 模式生效）
SA_EMBEDDING_API_KEY=${EMBEDDING_API_KEY}

# 向量库提供方：chroma=ChromaDB, milvus=Milvus, qdrant=Qdrant
SA_VECTOR_PROVIDER=milvus
# Milvus 主机地址（Docker 容器间使用服务名）
SA_VECTOR_MILVUS_HOST=milvus
# Milvus 端口
SA_VECTOR_MILVUS_PORT=19530
# Qdrant 服务地址（Qdrant 模式生效，Docker 容器间使用服务名）
SA_VECTOR_QDRANT_URL=http://qdrant:6333
# Qdrant 集合名称（Qdrant 模式生效）
SA_VECTOR_QDRANT_COLLECTION=super_agent_docs
# Qdrant API 密钥（Qdrant 模式生效，通过环境变量注入）
SA_VECTOR_QDRANT_API_KEY=${QDRANT_API_KEY}

# Redis 连接地址（Docker 容器间使用服务名）
SA_REDIS_URL=redis://redis:6379
# Redis 密码（通过环境变量注入）
SA_REDIS_PASSWORD=${REDIS_PASSWORD}

# MySQL 主机地址（Docker 容器间使用服务名）
SA_MYSQL_HOST=mysql
# MySQL 端口
SA_MYSQL_PORT=3306
# MySQL 用户名
SA_MYSQL_USERNAME=super_agent
# MySQL 密码（通过环境变量注入）
SA_MYSQL_PASSWORD=${MYSQL_PASSWORD}
# MySQL 数据库名
SA_MYSQL_DATABASE=super_agent

# 是否启用 LangSmith 追踪
SA_TRACING_ENABLE_LANGSMITH=false
# 是否启用 OpenTelemetry 追踪
SA_TRACING_ENABLE_OTEL=true
# OpenTelemetry Collector 导出地址
SA_TRACING_OTEL_EXPORTER=http://otel-collector:4317

# 服务监听端口
SA_SERVER_PORT=8000
# 日志级别：生产环境建议 INFO
SA_SERVER_LOG_LEVEL=INFO
# CORS 允许的来源域名列表（生产环境禁止使用通配符 *）
SA_SERVER_CORS_ORIGINS=["https://your-domain.com"]
